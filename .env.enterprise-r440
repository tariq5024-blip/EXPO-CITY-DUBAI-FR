# ═══════════════════════════════════════════════════════════════════════════
# ENTERPRISE CONFIGURATION - Dell R440 Unlimited Scale
# Copy to .env for production deployment
# ═══════════════════════════════════════════════════════════════════════════

# ── Core API ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# MongoDB with high connection pool (R440 has RAM for this)
MONGODB_URI=mongodb://mongo:27017/expo-fr?maxPoolSize=500&minPoolSize=50&maxIdleTimeMS=60000
# Or for dedicated MongoDB host:
# MONGODB_URI=mongodb://192.168.0.10:27017/expo-fr?maxPoolSize=500&replicaSet=rs0

# ── Scaling Limits (Unlimited Configuration) ───────────────────────────────

# Pagination - allow massive exports
JSON_BODY_LIMIT=100mb
REQUEST_TIMEOUT_MS=120000

# Rate limiting - higher for internal enterprise network
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5000
RATE_LIMIT_AUTH_MAX=200

# Device scaling - R440 can handle 500+ devices
DEVICE_EVENT_PULL_MS=500           # Faster polling
DEVICE_EVENT_PULL_CONCURRENCY=64   # Up from 20
DEVICE_PHOTO_BACKFILL_WINDOW=5000  # Larger backfill
DEVICE_PHOTO_BACKFILL_EVERY_MS=30000

# Device sync queue - higher throughput
DEVICE_SYNC_QUEUE_ENABLED=true
DEVICE_SYNC_QUEUE_TICK_MS=15000    # Faster retry
DEVICE_SYNC_MAX_RETRIES=20
DEVICE_SYNC_BATCH_SIZE=50          # Up from 20

# Device sync unlimited retention - critical for enterprise (24h/1week+ offline devices)
DEVICE_SYNC_UNLIMITED_RETENTION=true
DEVICE_SYNC_MAX_RETRY_DELAY_MS=3600000  # 1 hour between retries

# Visitor device sync - enterprise feature
DEVICE_REVOKE_ON_VISITOR_REMOVE=true
VISITOR_ENROLLMENT_PUSH_DEVICES=true

# Face enrollment at scale
FACE_AUTO_REFRESH_ENABLED=true
FACE_AUTO_REFRESH_TICK_MS=180000   # 3 minutes
FACE_AUTO_REFRESH_IDLE_MS=60000
FACE_AUTO_REFRESH_MIN_GAP_MS=86400000
FACE_AUTO_REFRESH_BATCH=10         # Up from 2

# GSDK timeouts for large deployments
GSDK_SIDECAR_HTTP_MS=60000
GSDK_ENROLL_MS=180000
GSDK_PUSH_FACE_NORMALIZE_PASSES=3
GSDK_PUSH_FACE_EXTRACT_PASSES=5
GSDK_PUSH_FACE_PASS_DELAY_MS=500

# Self-healing - more aggressive at scale
SELF_HEALING_ENABLED=true
SELF_HEALING_TICK_MS=10000
SELF_HEALING_FAIL_THRESHOLD=2
SELF_HEALING_COOLDOWN_MS=15000

WATCHDOG_ENABLED=true
WATCHDOG_TICK_MS=10000
WATCHDOG_STALE_PULL_MS=30000

# ── Log Retention (Adjust Based on Storage) ────────────────────────────────
# 0 = unlimited (R440 with 4TB+ SSD can hold years)
# Or set to 730 for 2-year rolling retention
LOG_RETENTION_DAYS=0

# Large footprint queries
FOOTPRINT_LOG_LIMIT=500000

# ── Suprema Device Gateway ────────────────────────────────────────────────
GSDK_GATEWAY=host.docker.internal:4100
GSDK_USE_SSL=true
GSDK_TLS_CA=/opt/gateway-cert/ca.crt
GSDK_SIDECAR_URL=http://gsdk-sidecar:4500
GSDK_DEVICE_PORT=51211
GSDK_RPC_PORT=4100

# Access groups for enterprise
SUPREMA_ACCESS_GROUP_IDS=1,2,3,4,5
GSDK_DEFAULT_AUTH_GROUP=1

# Enrollment settings
ENROLLMENT_PUSH_DEVICES=true
LIVE_ENROLL_PUSH_FACE_FALLBACK=true
DEVICE_REVOKE_ON_EMPLOYEE_REMOVE=true

# ── Central API (Hybrid Mode for Large Deployments) ──────────────────────
CENTRAL_API_ENABLED=false
# CENTRAL_API_BASE_URL=https://api.central.company.com
# CENTRAL_API_API_KEY=
CENTRAL_API_POLL_MS=30000
CENTRAL_API_AUTO_PUSH_TO_READERS=true

# ── AI/Ollama ──────────────────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
AI_INSIGHTS_REFRESH_MS=300000      # 5 minutes at scale

# ── Security ───────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_32_CHAR_SECRET_MINIMUM
ADMIN_USER=admin
ADMIN_PASS=CHANGE_THIS_STRONG_PASSWORD

# ── Application URLs ───────────────────────────────────────────────────────
APP_BASE_URL=http://192.168.0.200:4000

# ── CORS (Lock down for production) ───────────────────────────────────────
# CORS_ORIGINS=https://fr.company.com,https://kiosk.company.com

