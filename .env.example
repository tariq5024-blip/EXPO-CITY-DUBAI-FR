PORT=4000
MONGODB_URI=mongodb://localhost:27017/expo-fr
# API driver pool size (raise for many concurrent requests; cap per MongoDB deployment limits).
# MONGODB_MAX_POOL_SIZE=100
# Ollama API (backend uses Ollama npm client). For `node backend` on the host, localhost is correct.
# When the API runs in Docker (docker-compose.yml), the backend service always uses http://ollama:11434 — do not rely on this line there.
OLLAMA_HOST=http://localhost:11434
# Visitor check-in QR files (PNG + contact.json) — default data/visitor-qr-codes under API cwd; Docker uses /app/data/visitor-qr-codes (volume).
# VISITOR_QR_STORAGE_ENABLED=true
# VISITOR_QR_STORAGE_DIR=/app/data/visitor-qr-codes

# --- Suprema device_gateway (gRPC rpc_server port — NOT the reader TCP port 51211) ---
# LAN example (gateway on same PC as BioStar / device_gateway): use that host IP.
# GSDK_GATEWAY=192.168.0.200:4100
# Backend in Docker reaching gateway on the host (compose adds extra_hosts for this):
# GSDK_GATEWAY=host.docker.internal:4100
GSDK_GATEWAY=127.0.0.1:4100
GSDK_SIDECAR_URL=http://localhost:4500
# Sidecar must accept large JSON for /enrollment/push-face (base64 photos). Default in code is 12mb.
# GSDK_JSON_BODY_LIMIT=12mb
# device_gateway rpc_server uses TLS on 4100 — sidecar needs CA (see docker-compose volume).
GSDK_USE_SSL=true
# Auto-call Connect.SetAcceptFilter (allowAll) via sidecar — required after gateway restarts or devices show "not allowed".
AUTO_SET_ACCEPT_FILTER=true
ACCEPT_FILTER_REFRESH_MS=120000
# Dev only: allow GET /api/gsdk/diagnostics without JWT (exposes gateway IP in JSON). Never enable in production.
# GSDK_DIAGNOSTICS_OPEN=true
# CA must sign gateway server.crt (reissue with SANs if gRPC reports peer name mismatch).
GSDK_TLS_CA=/opt/gateway-cert/ca.crt
GSDK_DEVICE_PORT=51211
# BioStar access group for enroll / SetAccessGroup (G-SDK). If the user’s group is not allowed on the door’s Access Level, events show 0x1900 (ACCESS_DENIED) sub 0x01 = invalid access group.
# 1) In BioStar 2: note the Access Group ID(s) of the people who may use the door (Access Control → Access Groups — numeric ID in list/grid).
# 2) Match the door / reader “Floor level” or door Access Level so it allows those group IDs (Door settings → access schedule / group mapping — wording varies by BioStar version).
# 3) Set ONE of the following so Expo-FR pushes the same IDs onto the reader with enroll/reapply:
# DEFAULT_SUPREMA_ACCESS_GROUP=<same numeric ID as BioStar>
# Or multiple: SUPREMA_ACCESS_GROUP_IDS=2,3
# Restart backend + gsdk-sidecar after edits (both load .env). Then: POST /api/employees/<MongoDB _id>/reapply-access-groups with JWT, or Live enroll / Sync face again.
# After web Face Enrollment, push Visual Face to readers via sidecar (Face.Normalize→Extract→User.Enroll). Requires supremaDeviceId on each device (use Sync on My Devices).
# ENROLLMENT_PUSH_DEVICES=true
# On employee delete or suspend (status/cardholder), call sidecar User.Delete so readers drop the face template (Mongo-only delete leaves templates cached).
# DEVICE_REVOKE_ON_EMPLOYEE_REMOVE=true
# GSDK_ENROLL_MS=60000
# push-face (remote photo only): strict Suprema workflow retries (Normalize -> Extract(isWarped=true) -> Enroll).
# GSDK_PUSH_FACE_NORMALIZE_PASSES=2
# GSDK_PUSH_FACE_EXTRACT_PASSES=3
# GSDK_PUSH_FACE_PASS_DELAY_MS=700
# Log Face.Extract raw byte length per attempt (sidecar): GSDK_PUSH_FACE_DEBUG=1
# Live scan-and-enroll: default sends full scan FaceData (templates + image, EX stripped) like a working manual shell→SetFace flow.
# Set true to send image bytes only (JPEG uses flag 0, not WARPED). BS3: false is usually best.
# GSDK_SCAN_ENROLL_IMAGE_ONLY=false
# Delete device user before shell enroll (matches manual “delete then bare user” — clears stale credentials).
# GSDK_SCAN_DELETE_BEFORE_ENROLL=true
# Permanent lock for stable Visual Face persistence (do not lower in production):
# - Sidecar uses EX+TEMPLATE_ONLY then TEMPLATE_ONLY fallback in code (locked profile)
# - Keep scan retry delay to avoid transient extract failures on busy reader links
# GSDK_SCAN_ENROLL_RETRY_DELAY_MS=1200
# Keep long enroll timeout for normalize/extract/enroll + verify path
# GSDK_ENROLL_MS=120000
# If live scan still fails, API /api/employees/:id/live-enroll automatically tries push-face with the employee's stored enrollment photo (same as Sync face). Disable with false.
# LIVE_ENROLL_PUSH_FACE_FALLBACK=true
# gRPC Connect/Event API on device_gateway (rpc_server); default 4100 — not the reader port 51211.
# GSDK_RPC_PORT=4100
# How often the backend pulls reader logs via sidecar (GET_LOG). Default 1000 ms for near-live scan photos.
# DEVICE_EVENT_PULL_MS=1000
# Max parallel device pulls per tick (~200 readers: avoids hammering gateway). Default 20.
# DEVICE_EVENT_PULL_CONCURRENCY=20
# Historical photo backfill: periodically re-pull a larger event-id window so already-inserted rows can get missing scan photos.
# DEVICE_PHOTO_BACKFILL_WINDOW=1200
# DEVICE_PHOTO_BACKFILL_EVERY_MS=60000
# Keep only rolling N-day logs in MongoDB (TTL). 100 = keep last 100 days.
# LOG_RETENTION_DAYS=100
# API reliability guardrails.
# REQUEST_TIMEOUT_MS=30000
# JSON_BODY_LIMIT=15mb
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=1200
# RATE_LIMIT_AUTH_MAX=60
# Central API hybrid integration (Pull central API, Push to readers, Reader events push back).
# CENTRAL_API_ENABLED=false
# CENTRAL_API_BASE_URL=
# CENTRAL_API_API_KEY=
# CENTRAL_API_USERS_PATH=/users
# CENTRAL_API_DEVICES_PATH=/devices
# CENTRAL_API_POLL_MS=60000
# CENTRAL_API_TIMEOUT_MS=15000
# CENTRAL_API_AUTO_PUSH_TO_READERS=true
# After clearing reader logs or counter reset, Mongo lastEventId can point past the device — incremental pulls return empty. Backend probes with GetLog(start=0); if the full log fits under this limit and max(id) < lastEventId, it clears lastEventId and resyncs.
# DEVICE_LOG_RECOVERY_PROBE_LIMIT=2000
# One face denial can emit several BioStar rows in the same second; collapse to one row per device per second (set false for full audit trail).
# DEVICE_LOG_COLLAPSE_AUTH_BURST=true
# Idle-time automatic face refresh from successful scan activity:
# Queue employee after successful scan + photo, then push face template to readers only when system is idle/free.
# Keep enabled for permanent reader alignment.
# FACE_AUTO_REFRESH_ENABLED=true
# Worker tick frequency.
# FACE_AUTO_REFRESH_TICK_MS=300000
# Minimum inactivity window (no recent device event ingest) before refresh starts.
# FACE_AUTO_REFRESH_IDLE_MS=180000
# Per-employee minimum gap between auto refresh runs (daily by default).
# FACE_AUTO_REFRESH_MIN_GAP_MS=86400000
# Max employees processed per idle run.
# FACE_AUTO_REFRESH_BATCH=2
# Self-healing control loop (sidecar/gateway/device flow):
# Automatically detects sidecar instability or stale event pulls and triggers recovery actions:
# - re-apply SetAcceptFilter
# - refresh device health map
# - force one event pull recovery cycle
# Keep enabled in production.
# SELF_HEALING_ENABLED=true
# SELF_HEALING_TICK_MS=15000
# SELF_HEALING_FAIL_THRESHOLD=2
# SELF_HEALING_COOLDOWN_MS=20000
# AI insights backend refresh cache (15 min default).
# AI_INSIGHTS_REFRESH_MS=900000
# Watchdog (extra guard rail): if event pull appears stalled, force recovery immediately
# and chain self-healing actions.
# WATCHDOG_ENABLED=true
# WATCHDOG_TICK_MS=15000
# WATCHDOG_STALE_PULL_MS=45000
SUPREMA_HOST=127.0.0.1:4100
SUPREMA_PORT=4100
SUPREMA_SSL=false
JWT_SECRET=expo-fr-dev-secret
ADMIN_USER=admin
ADMIN_PASS=admin123
# Optional: password for the superadmin row created by `npm run seed` (default: password)
# SEED_SUPERADMIN_PASSWORD=password
APP_BASE_URL=http://localhost:4000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Log & Footprint Limits ─────────────────────────────────────────────
# Maximum number of logs returned per footprint query (default: 10000, max: 500000)
# FOOTPRINT_LOG_LIMIT=10000

# Log retention TTL in days (0 or unset = unlimited, recommended for large deployments)
# LOG_RETENTION_DAYS=0

# ── CORS Allowlist (Production) ────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty for permissive dev mode.
# CORS_ORIGINS=https://app.expocity.ae,https://kiosk.expocity.ae

# ── Production Mode Hardening ──────────────────────────────────────────
# Set NODE_ENV=production to enforce:
#  - JWT_SECRET must be set (min 16 chars), no dev fallback
#  - ADMIN_PASS must be set (min 8 chars), no dev fallback
# NODE_ENV=production

# ── Scaling Targets (this build is tuned for) ──────────────────────────
# • Employees:     up to 6,000
# • Companies:     up to 100 (tenant organizations)
# • Devices:       unlimited (tested up to 100 readers)
# • Logs:          unlimited (set LOG_RETENTION_DAYS to enable rolling expiry)
# • Concurrent users: 50+
#
# For 6,000+ employees, ensure MongoDB instance has at least:
#   - 4 GB RAM allocated to the mongod process
#   - SSD storage (HDDs will be I/O bound on large queries)
#   - Indexes pre-built (the backend does this automatically on startup)
